{
  "manifest_version": 3,
  "name": "SecurePass Studio",
  "version": "1.0.0",
  "description": "Password strength checker and smart generator.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SecurePass Studio",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; style-src 'self'; img-src 'self'"
  }
}
